# Environment Configuration — Basketball Grader Wizard
# Copy this file to .env and fill in your credentials

# === Optional API / LLM Configuration ===
# Only needed if you connect this app to an external service
API_CLIENT_ID="<your-client-id>"
API_CLIENT_SECRET="<your-client-secret>"
API_BASE_URL="https://api.example.com/v1"
API_SCOPE="api://your-app-id/.default"
LLM_MODEL="your-model-name"

# === Proxy Configuration (optional) ===
# Only needed when running behind an outbound corporate proxy
HTTPS_PROXY="http://proxy.example.com:8080"

# === Tokenizer Settings ===
TOKENIZERS_PARALLELISM=false

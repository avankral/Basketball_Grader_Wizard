# Environment Configuration — Basketball Grader Wizard
# Copy this file to .env and fill in your credentials

# === Ford LLM Configuration (optional) ===
# Only needed for LLM-enabled projects
FORD_CLIENT_ID="<your-azure-app-client-id>"
FORD_CLIENT_SECRET="<your-client-secret>"
BASE_ENDPOINT="https://api.pivpn.core.ford.com/fordllmapi/secret_data_api/v1"
SCOPE="api://6af47983-2540-43ae-89ff-4b93bf4eeb33/.default"
LLM_MODEL="gemini-2.5-flash-lite"

# === Proxy Configuration ===
# Required for outbound requests on Ford network
HTTPS_PROXY="http://internet.ford.com:83"

# === Tokenizer Settings ===
TOKENIZERS_PARALLELISM=false
